{
  "name": "vps-mount",
  "version": "1.0.0",
  "description": "Mount VPS filesystem as a Windows drive letter via SSHFS",
  "license": "MIT",
  "author": "Kadeem Johnson (Cleanera Made)",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleaneramade/vps-mount.git"
  },
  "homepage": "https://github.com/cleaneramade/vps-mount#readme",
  "bugs": {
    "url": "https://github.com/cleaneramade/vps-mount/issues"
  },
  "main": "src/main/main.js",
  "scripts": {
    "build:icon": "electron scripts/convert-logo.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.vpsmount.app",
    "productName": "VPS Mount",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VPS Mount"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!scripts/**/*"
    ]
  }
}
